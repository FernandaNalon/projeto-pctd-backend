generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  nome         String    @db.VarChar(150)
  email        String    @unique @db.VarChar(150)
  senhaHash    String    @map("senha_hash") @db.VarChar(255)
  role         UserRole  @default(DOCENTE)
  ativo        Boolean   @default(true)
  fotoPerfil   String?   @map("foto_perfil") @db.VarChar(255)
  ultimoLogin  DateTime? @map("ultimo_login") @db.DateTime(0)
  refreshToken String?   @map("refresh_token") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(0)

  unidadesCurriculares UnidadeCurricular[]    @relation("UcDocente")
  aulas                Aula[]                 @relation("AulaDocente")
  observacoes          ObservacaoPedagogica[] @relation("ObsDocente")
  auditLogs            AuditLog[]

  @@map("user")
}

model Turma {
  id         String       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  nome       String       @db.VarChar(150)
  periodo    PeriodoTurma
  curso      String       @db.VarChar(150)
  anoLetivo  Int?         @map("ano_letivo")
  semestre   Int?
  dataInicio DateTime     @map("data_inicio") @db.Date
  dataFim    DateTime?    @map("data_fim") @db.Date
  status     StatusTurma  @default(ATIVA)
  createdAt  DateTime     @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt  DateTime?    @map("deleted_at") @db.DateTime(0)

  alunos      Aluno[]
  ucs         UnidadeCurricular[]
  observacoes ObservacaoPedagogica[]

  @@map("turma")
}

model Aluno {
  id           String      @id @default(dbgenerated("(uuid())")) @db.Char(36)
  idInterno    String?     @unique @map("id_interno") @db.VarChar(50)
  nomeCompleto String      @map("nome_completo") @db.VarChar(180)
  email        String?     @unique @db.VarChar(150)
  telefone     String?     @db.VarChar(30)
  status       StatusAluno @default(ATIVO)
  turmaId      String      @map("turma_id") @db.Char(36)
  createdAt    DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt    DateTime?   @map("deleted_at") @db.DateTime(0)

  turma       Turma                  @relation(fields: [turmaId], references: [id])
  observacoes ObservacaoPedagogica[]

  @@index([turmaId])
  @@map("aluno")
}

model UnidadeCurricular {
  id           String    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  nome         String    @db.VarChar(180)
  cargaHoraria Int       @map("carga_horaria")
  quantAulas   Int       @map("quant_aulas")
  ordem        Int?
  dataInicio   DateTime? @map("data_inicio") @db.Date
  dataFim      DateTime? @map("data_fim") @db.Date
  turmaId      String    @map("turma_id") @db.Char(36)
  docenteId    String    @map("docente_id") @db.Char(36)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(0)

  turma   Turma  @relation(fields: [turmaId], references: [id])
  docente User   @relation("UcDocente", fields: [docenteId], references: [id])
  aulas   Aula[]

  @@index([turmaId])
  @@index([docenteId])
  @@map("unidade_curricular")
}

model Aula {
  id                   String    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  data                 DateTime  @db.Date
  numeroAula           Int       @map("numero_aula")
  tema                 String    @db.VarChar(200)
  conteudoDesenvolvido String    @map("conteudo_desenvolvido") @db.Text
  atividadesRealizadas String?   @map("atividades_realizadas") @db.Text
  observacoes          String?   @db.Text
  ucId                 String    @map("uc_id") @db.Char(36)
  docenteId            String    @map("docente_id") @db.Char(36)
  createdAt            DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt            DateTime? @map("deleted_at") @db.DateTime(0)

  uc          UnidadeCurricular @relation(fields: [ucId], references: [id])
  docente     User              @relation("AulaDocente", fields: [docenteId], references: [id])
  indicadores AulaIndicador[]

  @@index([ucId])
  @@index([docenteId])
  @@map("aula")
}

model Indicador {
  id        String    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  descricao String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(0)

  aulas AulaIndicador[]

  @@map("indicador")
}

model AulaIndicador {
  aulaId      String @map("aula_id") @db.Char(36)
  indicadorId String @map("indicador_id") @db.Char(36)

  aula      Aula      @relation(fields: [aulaId], references: [id])
  indicador Indicador @relation(fields: [indicadorId], references: [id])

  @@id([aulaId, indicadorId])
  @@index([indicadorId])
  @@map("aula_indicador")
}

model ObservacaoPedagogica {
  id         String             @id @default(dbgenerated("(uuid())")) @db.Char(36)
  titulo     String             @db.VarChar(180)
  descricao  String             @db.Text
  categoria  CategoriaRegistro  @default(PEDAGOGICA)
  prioridade PrioridadeRegistro @default(MEDIA)
  status     StatusRegistro     @default(ABERTO)
  data       DateTime           @db.Date

  turmaId   String? @map("turma_id") @db.Char(36)
  alunoId   String? @map("aluno_id") @db.Char(36)
  docenteId String  @map("docente_id") @db.Char(36)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)

  turma   Turma? @relation(fields: [turmaId], references: [id])
  aluno   Aluno? @relation(fields: [alunoId], references: [id])
  docente User   @relation("ObsDocente", fields: [docenteId], references: [id])

  @@index([turmaId])
  @@index([alunoId])
  @@index([docenteId])
  @@map("observacao_pedagogica")
}

model AuditLog {
  id           String      @id @default(dbgenerated("(uuid())")) @db.Char(36)
  userId       String      @map("user_id") @db.Char(36)
  action       AuditAction
  entidade     String      @db.VarChar(100)
  entidadeId   String      @map("entidade_id") @db.Char(36)
  dadosAntigos String?     @map("dados_antigos") @db.LongText
  dadosNovos   String?     @map("dados_novos") @db.LongText
  ipAddress    String?     @map("ip_address") @db.VarChar(80)
  userAgent    String?     @map("user_agent") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at") @db.DateTime(0)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entidade, entidadeId])
  @@map("audit_log")
}

enum UserRole {
  ADMIN
  COORDENACAO
  DOCENTE
}

enum PeriodoTurma {
  MANHA
  TARDE
  NOITE
}

enum StatusTurma {
  ATIVA
  ENCERRADA
  CANCELADA
}

enum StatusAluno {
  ATIVO
  EVADIDO
  TRANSFERIDO
  CONCLUIDO
}

enum AuditAction {
  CRIACAO
  ATUALIZACAO
  EXCLUSAO
  LOGIN
  LOGOUT
}

enum CategoriaRegistro {
  PEDAGOGICA
  COMUNICADO
  ACOMPANHAMENTO
}

enum PrioridadeRegistro {
  BAIXA
  MEDIA
  ALTA
}

enum StatusRegistro {
  ABERTO
  EM_ANDAMENTO
  CONCLUIDO
}
